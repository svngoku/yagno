# ─────────────────────────────────────────────────────────────────
#  Yagno Docker environment
#  Copy to .env and fill in your API keys:
#    cp .env.docker.example .env
# ─────────────────────────────────────────────────────────────────

# ── Model provider keys (at least one required) ─────────────────
OPENROUTER_API_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# ── Search tool ─────────────────────────────────────────────────
# TAVILY_API_KEY=

# ── Daytona sandbox (optional) ──────────────────────────────────
# DAYTONA_API_KEY=

# ── PostgreSQL (used by docker-compose) ─────────────────────────
POSTGRES_USER=yagno
POSTGRES_PASSWORD=yagno
POSTGRES_DB=yagno
# POSTGRES_PORT=5432

# ── Yagno server port ──────────────────────────────────────────
# YAGNO_PORT=8000
